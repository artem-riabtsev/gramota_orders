{% extends 'base.html.twig' %}

{% block title %}Вход{% endblock %}

{% block content %}
<div class="card shadow-lg border-0">
    <div class="card-body p-4 p-md-5">
        <div class="text-center mb-4">
            <h2 class="fw-bold">Вход в систему</h2>
            <p class="text-muted small">Введите ваши данные для доступа</p>
        </div>

        {% if error %}
            <div class="alert alert-danger py-2 small border-0 shadow-sm">Неверный логин или пароль.</div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="mb-3">
                <label for="username" class="form-label small fw-semibold">Логин (Email)</label>
                <input type="email" name="email" id="username" value="{{ last_username }}" required class="form-control form-control-lg bg-light border-0" placeholder="email@example.com" autofocus>
            </div>

            <div class="mb-4">
                <label for="password" class="form-label small fw-semibold">Пароль</label>
                <input type="password" name="password" id="password" class="form-control form-control-lg bg-light border-0" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">
                Войти в CRM
            </button>
        </form>
    </div>
</div>
{% endblock %}