<form method="post" action="{{ path('app_price_delete', {'id': price.id}) }}" onsubmit="return confirm('Вы уверены, что хотите удалить этот прайс?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ price.id) }}">
    <button type="submit" class="btn p-0" 
            style="background: none; border: none; color: #dc3545; font-size: 1.5rem; line-height: 1;"
        >
        <i class="bi bi-x"></i>
    </button>
</form>