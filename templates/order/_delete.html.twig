<form method="post" action="{{ path('app_order_delete', {'id': order.id, 'redirect': app.request.requestUri}) }}" onsubmit="return confirm('Вы уверены, что хотите удалить этот заказ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
    <button type="submit" class="btn p-0" style="background: none; border: none; color: #dc3545; font-size: 1.5rem; line-height: 1;">
        <i class="bi bi-x"></i>
    </button>
</form>