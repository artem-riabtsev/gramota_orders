{% extends 'base.html.twig' %}

{% block title %}Выбор позиции из прайса{% endblock %}

{% block content %}
<div class="container mt-4">
    <h4>Выбор позиции из прайса</h4>

    <form method="get" class="mb-3" style="flex-grow-1 me-md-3">
        <div class="col-12 col-md-8 d-flex gap-2">
            <div class="input-group w-50">
                <input type="text"
                    name="q"
                    class="form-control"
                    placeholder="Поиск по прайсу"
                    value="{{ searchQuery }}">
                <button class="btn btn-secondary" type="submit" title="Поиск">
                    <i class="bi bi-search text-white"></i>
                </button>
            </div>
            {% if searchQuery %}
                <a href="{{ path('app_order_template', {'id': order.id}) }}" 
                class="btn btn-outline-secondary d-flex align-items-center">
                    <i class="bi bi-x-lg"></i>
                </a>
            {% endif %}
        </div>
    </form>

    <div id="price-list" class="list-group mb-3" style="max-height: 300px; overflow-y: auto;">
    <button class="list-group-item list-group-item-action price-select" data-id="">
        Не использовать прайс
    </button>
        {% for price in prices %}
            <button type="button"
                    class="list-group-item list-group-item-action price-select"
                    data-id="{{ price.id }}">
                {{ price.description }}
            </button>
        {% endfor %}
    </div>

    {{ form_start(form, {
            'action': path('app_orderItem_new'),
            'method': 'GET',
            'name': '',
            'attr': {'id': 'template-form'}
        }) }}
        {{ form_widget(form.price, {'attr': {'name': 'price', 'style': 'display: none;'}}) }}
        <input type="hidden" name="order" value="{{ order.id }}">
    {{ form_end(form) }}

    <a href="{{ path('app_order_show', {'id': order.id}) }}" class="btn btn-secondary">
        Назад
    </a>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const priceList = document.getElementById('price-list');
    const orderForm = document.getElementById('template-form');
    const priceField = orderForm.querySelector('select');
    
    priceList.querySelectorAll('.price-select').forEach(button => {
        button.addEventListener('click', function() {
            const clickedId = this.getAttribute('data-id');
            priceField.value = clickedId;
            orderForm.submit();
        });
    });
});
</script>
<style>
.price-select {
    cursor: pointer;
    transition: background-color 0.2s ease;
}
.price-select:hover {
    background-color: #f8f9fa;
}
</style>
{% endblock %}