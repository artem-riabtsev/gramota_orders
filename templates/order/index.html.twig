{% extends 'base.html.twig' %}

{% block title %}Заказы — Gramota CRM{% endblock %}

{% block title_h2 %}Заказы{% endblock %}

{% block top_actions %}
    <a href="{{ path('app_order_new') }}" class="btn btn-primary shadow-sm fw-semibold">
        <i class="bi bi-plus-lg me-1"></i> Новый заказ
    </a>
{% endblock %}

{% block content %}

<div class="mb-4">
    {% include 'order/_filter.html.twig' %}
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 text-secondary small fw-semibold">ID</th>
                        <th class="py-3 text-secondary small fw-semibold">Дата</th>
                        <th class="py-3 text-secondary small fw-semibold">Заказчик</th>
                        <th class="py-3 text-secondary small fw-semibold">Сумма заказа</th>
                        <th class="py-3 text-secondary small fw-semibold">Оплачено</th>
                        <th class="py-3 text-secondary small fw-semibold">Статус</th>
                        <th class="text-end pe-4 py-3 text-secondary small fw-semibold">Действия</th>
                    </tr>
                </thead>
                <tbody>
                {% for order in orders %}
                    <tr>
                        <td class="ps-4">
                            <a href="{{ path('app_order_show', {'id': order.id}) }}" class="fw-bold text-decoration-none">
                                #{{ order.id }}
                            </a>
                        </td>
                        
                        <td class="text-muted">{{ order.date ? order.date|date('d.m.Y') : '—' }}</td>
                        
                        <td>
                            <a href="{{ path('app_customer_show', {'id': order.customer.id}) }}" class="text-dark fw-medium text-decoration-none">
                                {{ order.customer.name }}
                            </a>
                        </td>
                        
                        <td class="fw-bold">
                            {% if order.orderTotal and order.orderTotal.amount %}
                                {{ (order.orderTotal.amount.toFloat())|number_format(2, '.', ' ') }} ₽
                            {% else %}
                                0.00 ₽
                            {% endif %}
                        </td>

                        <td class="text-muted">
                            {% if order.totalPaid and order.totalPaid.amount %}
                                {{ (order.totalPaid.amount.toFloat())|number_format(2, '.', ' ') }} ₽
                            {% else %}
                                0.00 ₽
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge {{ order.status.color }} bg-opacity-10 px-2 py-1 rounded-pill" style="color: var(--bs-{{ order.status.color|replace({'text-': ''}) }}); background-color: rgba(var(--bs-{{ order.status.color|replace({'text-': ''}) }}-rgb), 0.1);">
                                {{ order.status.label }}
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                {% include 'order/_delete.html.twig' %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">Заказы не найдены</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}