{% extends 'base.html.twig' %}

{% block title %}Платежи{% endblock %}

{% block content %}
    <h1>Платежи</h1>

    {% include 'search/search_form.html.twig' %}
    {# {% include 'modals/modal_delete.html.twig' %} #}

    <table class="table table-hover  align-middle">
        <thead>
            <tr>
                <th>Id</th>
                <th>Номер заказа</th>
                <th>Дата</th>
                <th>Сумма платежа</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {% for payment in payments %}
            <tr>
                <td>{{ payment.id }}</td>
                <td>
                    <a href="{{ path('app_order_show', {'id': payment.order.id}) }}" 
                        class="text-muted me-2" style="text-decoration: underline; text-decoration-thickness: 1px;">
                        {{ payment.order.id }}
                    </a>
                    <a href="{{ path('app_payment_edit', {'id': payment.id}) }}" class="btn p-0 mb-1">
                        <i class="bi bi-pencil" style="font-size: 1rem; color: #6c757d;"></i>
                    </a>
                </td>
                <td>{{ payment.date ? payment.date|date('d.m.Y') : '' }}</td>
                <td>{{ payment.amount.amount }}</td>
                <td>
                    <div class="d-flex justify-content-center">
                        <button
                            type="button"
                            class="btn bp-0 remove-item"
                            data-id="{{ payment.id }}"
                            data-token="{{ csrf_token('delete' ~ payment.id) }}"
                            data-url="{{ path('app_payment_delete', {'id': payment.id}) }}"
                            style="background: none; border: none; color: #dc3545; font-size: 1.5rem; line-height: 1;"
                        >
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Платежи не найдены</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
