{% extends 'base.html.twig' %}

{% block title %}Платежи — Gramota CRM{% endblock %}

{% block title_h2 %}Платежи{% endblock %}

{% block top_actions %}
    <a href="{{ path('app_payment_new') }}" class="btn btn-primary shadow-sm fw-semibold">
        <i class="bi bi-plus-lg me-1"></i> Добавить платеж
    </a>
{% endblock %}

{% block content %}
    <div id="payments-search-root"></div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('app') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('app') }}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const root = document.getElementById('payments-search-root');
            if (window.LiveSearchTable && window.PaymentsTable) {
                const reactRoot = window.ReactDOM.createRoot(root);
                reactRoot.render(window.React.createElement(window.LiveSearchTable, {
                    apiUrl: '/api/payment/list',
                    placeholder: 'Поиск по номеру заказа...',
                    showCreateButton: false,
                    TableComponent: window.PaymentsTable,
                    emptyMessage: 'Платежи не найдены'
                }));
            }
        });
    </script>
{% endblock %}