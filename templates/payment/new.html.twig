{% extends 'base.html.twig' %}

{% block content %}
<div class="container mt-4">
    <h4>Выберите заказ</h4>

    <form method="get" class="mb-3" style="flex-grow-1 me-md-3">
        <div class="col-12 col-md-8 d-flex gap-2">
            <div class="input-group w-50">
                <input type="text"
                    name="q"
                    class="form-control"
                    placeholder="Поиск по номеру заказа"
                    value="{{ searchQuery }}">
                <button class="btn btn-secondary" type="submit" title="Поиск">
                    <i class="bi bi-search text-white"></i>
                </button>
            </div>
            {% if searchQuery %}
                <a href="{{ path('app_payment_new') }}" 
                class="btn btn-outline-secondary d-flex align-items-center">
                    <i class="bi bi-x-lg"></i>
                </a>
            {% endif %}
        </div>
    </form>

    <div id="order-list" class="list-group mb-3" style="max-height: 300px; overflow-y: auto;">
        {% for order in orders %}
            <button type="button"
                    class="list-group-item list-group-item-action order-select"
                    data-id="{{ order.id }}">
                Заказ #{{ order.id }} — {{ order.customer.name }}
            </button>
        {% else %}
            <div class="list-group-item text-muted">Ничего не найдено</div>
        {% endfor %}
    </div>

    {{ form_start(form, {'attr': {'id': 'payment-form'}}) }}
        {{ form_widget(form.order, {'attr': {'style': 'display: none;'}}) }}
    {{ form_end(form) }}

    <a href="{{ path('app_order_new') }}" class="btn btn-primary">Создать новый заказ</a>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const orderList = document.getElementById('order-list');
    const paymentForm = document.getElementById('payment-form');
    const orderField = paymentForm.querySelector('select');
    
    orderList.querySelectorAll('.order-select').forEach(button => {
        button.addEventListener('click', function() {
            const clickedId = this.getAttribute('data-id');
            orderField.value = clickedId;
            paymentForm.submit();
        });
    });
});
</script>
<style>
.order-select {
    cursor: pointer;
    transition: background-color 0.2s ease;
}
.order-select:hover {
    background-color: #f8f9fa;
}
</style>
{% endblock %}