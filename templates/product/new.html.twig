{% extends 'base.html.twig' %}

{% block title %}Новый продукт{% endblock %}

{% block content %}
<h1>Новый продукт</h1>

<div class="card">
    <div class="card-body">
        {{ form_start(form) }}

        <div class="row">
            {{ form_row(form.description) }}
            {{ form_row(form.date) }}
            {{ form_row(form.project) }}
            {{ form_row(form.basic) }}
        </div>

        <button class="btn btn-success">Создать</button>
        <a href="{{ app.request.headers.get('referer') ?: path('app_product_index') }}" class="btn btn-secondary ms-1">
            Назад
        </a>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}