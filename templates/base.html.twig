<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Gramota CRM{% endblock %}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.css">

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>
<body>
    <div class="d-flex">
        {% if app.user %}
        <nav class="sidebar d-flex flex-column flex-shrink-0 shadow">
            <div class="p-4">
                <h4 class="text-white fw-bold mb-0">Gramota <span class="text-info">Orders</span></h4>
            </div>
            
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a href="{{ path('app_order_index') }}" class="nav-link {{ app.request.attributes.get('_route') starts with 'app_order' ? 'active' : '' }}">
                        <i class="bi bi-cart3"></i> <span>Заказы</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_customer_index') }}" class="nav-link {{ app.request.attributes.get('_route') starts with 'app_customer' ? 'active' : '' }}">
                        <i class="bi bi-people"></i> <span>Клиенты</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_product_index') }}" class="nav-link {{ app.request.attributes.get('_route') starts with 'app_product' ? 'active' : '' }}">
                        <i class="bi bi-box"></i> <span>Продукты</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_price_index') }}" class="nav-link {{ app.request.attributes.get('_route') starts with 'app_price' ? 'active' : '' }}">
                        <i class="bi bi-tag"></i> <span>Прайс</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_payment_index') }}" class="nav-link {{ app.request.attributes.get('_route') starts with 'app_payment' ? 'active' : '' }}">
                        <i class="bi bi-credit-card"></i> <span>Платежи</span>
                    </a>
                </li>
            </ul>

            <hr class="mx-3 opacity-10">
            
            <div class="dropdown p-3 mt-auto">
                <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 12px;">
                        {{ app.user.email|slice(0,1)|upper }}
                    </div>
                    <span class="small">{{ app.user.email }}</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-dark text-small shadow" aria-labelledby="dropdownUser1">
                    <li><a class="dropdown-item" href="{{ path('app_logout') }}">Выйти</a></li>
                </ul>
            </div>
        </nav>
        {% endif %}

        <main class="main-content flex-grow-1 {% if not app.user %}d-flex align-items-center justify-content-center vh-100{% endif %}">
            <div class="{% if not app.user %}login-container{% else %}container-fluid{% endif %}">
                {% if app.user %}
                <header class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold mb-0">{% block title_h2 %}Панель управления{% endblock %}</h2>
                    <div class="actions">
                        {% block top_actions %}{% endblock %}
                    </div>
                </header>
                {% endif %}

                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} alert-dismissible fade show shadow-sm" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                {% block content %}{% endblock %}
            </div>
        </main>
    </div>

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.js"></script>
    {% endblock %}
</body>
</html>