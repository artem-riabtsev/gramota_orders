{% extends 'base.html.twig' %}

{% block content %}
    <h1>Редактировать заказчика {{ customer.id }}</h1>
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
            {{ form_widget(form) }}
            <button class="btn btn-success">Сохранить</button>
            <a href="{{ app.request.headers.get('referer') ?: path('app_order_index') }}" class="btn btn-secondary">
                Назад
            </a>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}