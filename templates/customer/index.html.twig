{% extends 'base.html.twig' %}

{% block title %}Клиенты — Gramota CRM{% endblock %}

{% block title_h2 %}Клиенты{% endblock %}

{% block top_actions %}
    <a href="{{ path('app_customer_new') }}" class="btn btn-primary shadow-sm fw-semibold">
        <i class="bi bi-person-plus me-1"></i> Новый клиент
    </a>
{% endblock %}

{% block content %}

<div class="mb-4">
    {% include 'customer/_filter.html.twig' %}
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 text-secondary small fw-semibold">Клиент</th>
                        <th class="py-3 text-secondary small fw-semibold">Контакты</th>
                        <th class="text-end pe-4 py-3 text-secondary small fw-semibold">Действия</th>
                    </tr>
                </thead>
                <tbody>
                {% for customer in customers %}
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div>
                                    <a href="{{ path('app_customer_show', {'id': customer.id}) }}" class="fw-bold text-dark text-decoration-none d-block">
                                        {{ customer.name }}
                                    </a>
                                    <span class="text-muted small">ID: {{ customer.id }}</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            {% if customer.email %}
                                <div class="small"><i class="bi bi-envelope me-2 text-muted"></i>{{ customer.email }}</div>
                            {% endif %}
                            {% if customer.phone %}
                                <div class="small"><i class="bi bi-telephone me-2 text-muted"></i>{{ customer.phone }}</div>
                            {% endif %}
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a href="{{ path('app_customer_show', {'id': customer.id}) }}" class="btn btn-sm btn-light text-primary border-0" title="Профиль">
                                    <i class="bi bi-person-vcard"></i>
                                </a>
                                <a href="{{ path('app_customer_edit', {'id': customer.id}) }}" class="btn btn-sm btn-light text-secondary border-0" title="Редактировать">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                {% include 'customer/_delete.html.twig' %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">Клиенты не найдены</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
