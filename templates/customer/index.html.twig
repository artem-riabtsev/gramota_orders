{% extends 'base.html.twig' %}

{% block title %}Заказчики{% endblock %}

{% block content %}
<h1>Заказчики</h1>
{% for message in app.flashes('error') %}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    {{ message }}
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
</div>
{% endfor %}
<div class="mb-4 d-flex flex-column flex-md-row justify-content-between gap-3">
    {% include 'customer/_filter.html.twig' %}
    <div class="flex-shrink-0">
        <a href="{{ path('app_customer_new') }}" class="btn btn-primary">
            Создать нового заказчика
        </a>
    </div>
</div>

<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Id</th>
            <th>ФИО</th>
            <th>Email</th>
            <th>Телефон</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    {% for customer in customers %}
        <tr>
            <td>{{ customer.id }}</td>
            <td class="d-flex" style="gap: 20px;">
                <a href="{{ path('app_customer_show', {'id': customer.id}) }}" class="text-muted" style="text-decoration: underline; text-decoration-thickness: 1px;">{{ customer.name }}</a>
                <a href="{{ path('app_customer_edit', {'id': customer.id}) }}" class="btn p-0">
                    <i class="bi bi-pencil" style="font-size: 1rem; color: #6c757d;"></i>
                </a>
            </td>
            <td>{{ customer.email }}</td>
            <td>{{ customer.phone }}</td>
            <td>
                <div class="d-flex justify-content-center">
                    {% include 'customer/_delete.html.twig' %}
                </div>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="7">Заказчики ненайдены</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{% endblock %}
