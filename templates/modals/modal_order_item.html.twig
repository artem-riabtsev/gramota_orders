<div class="modal fade" id="itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Новая позиция</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            {{ form_start(orderItemForm, {
                'attr': {
                    'id': 'itemForm',
                    'method': 'post',
                    'action': path('app_order_show', {'id': order.id})
                }
            }) }}
                <input type="hidden" name="_token" value="{{ csrf_token('edit' ~ order.id) }}">
                <input type="hidden" name="item_id" id="itemId">
                <div class="modal-body">
                    {{ form_widget(orderItemForm) }}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                </div>
            {{ form_end(orderItemForm) }}
        </div>
    </div>
</div>
{% for label, messages in app.flashes %}
    {% for message in messages %}
        notyf.open({
            type: '{{ label == "error" ? "error" : (label == "warning" ? "warning" : "success") }}',
            message: "{{ message|e('js') }}"
        });
    {% endfor %}
{% endfor %}

<script>
document.addEventListener('DOMContentLoaded', function() {
    const modal = new bootstrap.Modal('#itemModal');
    const itemForm = document.getElementById('itemForm');
    const modalTitle = document.getElementById('modalTitle');
    const itemIdInput = document.getElementById('itemId');
    const priceSourceSelect = document.getElementById('order_item_form_description');
    const productSelect = document.getElementById('order_item_form_product');
    const quantityInput = document.getElementById('order_item_form_quantity');
    const priceInput = document.getElementById('order_item_form_price');
    const totalInput = document.getElementById('order_item_form_line_total');
    const descriptionTextInput = document.getElementById('order_item_form_description_text');
    const allProductOptions = Array.from(productSelect.options);

    function handleTotalChange() {
        const quantity = parseInt(quantityInput.value) || 1;
        const total = parseFloat(totalInput.value) || 0;
        if (quantity > 0) {
            priceInput.value = (total / quantity).toFixed(2);
        }
    }

    // Обновление общей суммы
    function updateTotal() {
        const price = parseFloat(priceInput.value) || 0;
        const quantity = parseInt(quantityInput.value) || 1;
        totalInput.value = (price * quantity).toFixed(2);
    }

    // Фильтрация продуктов по project_id, учитываем allowEmpty для пустого значения
    function filterProductsByProject(allowEmpty = false) {
        const selectedOption = priceSourceSelect.options[priceSourceSelect.selectedIndex];
        const projectId = selectedOption ? selectedOption.getAttribute('data-project-id') : null;

        productSelect.innerHTML = '';

        let filteredOptions = allProductOptions.filter(opt => {
            const prodProjectId = opt.getAttribute('data-project-id');
            if (opt.value === '') {
                return allowEmpty; // показываем пустую опцию, если allowEmpty = true
            }
            // Показываем только опции с нужным project_id или если project_id не задан
            return !projectId || prodProjectId === projectId;
        });

        filteredOptions.forEach(opt => productSelect.appendChild(opt.cloneNode(true)));

        const currentProductId = productSelect.dataset.currentSelected || null;
        if (currentProductId) {
            const optionToSelect = Array.from(productSelect.options).find(opt => opt.value === currentProductId);
            if (optionToSelect) optionToSelect.selected = true;
            else productSelect.selectedIndex = allowEmpty ? 0 : -1;
        } else {
            productSelect.selectedIndex = allowEmpty ? 0 : -1;
        }
    }

    function limitPriceInput(input) {
    input.addEventListener('input', () => {
        let val = input.value;
        val = val.replace(/[^\d.]/g, '');
        const parts = val.split('.');
        parts[0] = parts[0].slice(0, 10);
        if (parts[1]) parts[1] = parts[1].slice(0, 2);
        input.value = parts.join('.');
    });
    }

    if (priceInput) limitPriceInput(priceInput);
    if (totalInput) limitPriceInput(totalInput);

    // Инициализация модалки для добавления
    document.getElementById('add-item')?.addEventListener('click', function() {
        modalTitle.textContent = 'Добавить позицию';
        itemIdInput.value = '';
        priceSourceSelect.selectedIndex = 0;

        // Сбрасываем products к полному списку
        productSelect.innerHTML = '';
        allProductOptions.forEach(opt => productSelect.appendChild(opt.cloneNode(true)));
        productSelect.selectedIndex = 0;

        quantityInput.value = '1';
        priceInput.value = '';
        totalInput.value = '';
        descriptionTextInput.value = '';

        modal.show();
    });

    // Обработка редактирования существующей позиции
    document.querySelectorAll('.edit-item').forEach(btn => {
        btn.addEventListener('click', function() {
            const itemId = this.dataset.id;
            const row = document.querySelector(`tr[data-id="${itemId}"]`);
            if (!row) return;

            modalTitle.textContent = 'Редактирование позиции';
            itemIdInput.value = itemId;

            const productId = row.dataset.productId;
            const description = row.dataset.description;
            const quantity = row.dataset.quantity;
            const price = row.dataset.price;
            const total = row.dataset.total;

            priceSourceSelect.value = description;
            descriptionTextInput.value = description;
            
            // Сохраняем в атрибут data текущий выбранный продукт
            productSelect.dataset.currentSelected = productId;

            // Фильтруем продукты по project_id выбранной позиции
            filterProductsByProject();

            quantityInput.value = quantity;
            priceInput.value = price;
            totalInput.value = total;

            modal.show();
        });
    });

    // Обработчики изменений количества и цены
    priceInput.addEventListener('input', updateTotal);
    totalInput.addEventListener('input', handleTotalChange);
    quantityInput.addEventListener('input', function() {
        if (priceInput.value) {
            updateTotal();
        } else {
            handleTotalChange();
        }
    });

    // При выборе позиции подставляем все данные
    priceSourceSelect.addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        if (selectedOption.value) {
            priceInput.value = selectedOption.dataset.price;
            const productId = selectedOption.dataset.productId;
            descriptionTextInput.value = selectedOption.value;

            // Запоминаем текущий выбранный продукт для фильтрации
            productSelect.dataset.currentSelected = productId;

            // Фильтруем продукты
            filterProductsByProject();

            quantityInput.value = '1';
            updateTotal();
        } else {
            // Если ничего не выбрано, сброс списка продуктов
            productSelect.innerHTML = '';
            allProductOptions.forEach(opt => productSelect.appendChild(opt.cloneNode(true)));
            productSelect.selectedIndex = 0;
            priceInput.value = '';
            totalInput.value = '';
            descriptionTextInput.value = '';
        }
    });

    itemForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const form = this;
        const formData = new FormData(form);
        
        // Простая отправка формы как есть
        fetch(form.action, {
            method: 'POST',
            body: formData
        }).then(response => {
            if (response.redirected) {
                window.location.href = response.url;
            }
        }).catch(error => {
            console.error('Error:', error);
            alert('Ошибка при сохранении');
        });
    });

    filterProductsByProject();
});
</script>